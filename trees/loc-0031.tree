\import{gabc-macros}
\title{Candlemas Chants}
\taxon{Ordo}
\subtree{
  \taxon{Antiphon}
  \title{At the lighting of the candles.}
\gabc{(c3)The(h) Lord(g) *() shall(e) come(g) to(h) us(f) with(e) migh(f)ty(e) pow(fe)er(d.) (;) bring(d)ing(f) light(h) to(h) eyes(g) of(e) those(ghf) who(f) serve(g) him(f) well(e.) (::) Thy (e) word(f) is..(hr0) (i) (hr0) (:) (hr0) (g) (h) (f) (e) (::)}
\ol{
  \li{Thy word is a lantern unto my \strong{feet} : and a light \em{un}to my paths.}
  \li{I have sworn, and am steadfastly \strong{pur}poséd : to keep thy \em{right}eous judgements.}
  \li{I am troubled above \strong{mea}sure : quicken me, O Lord, ac\em{cord}ing to thy word.}
  \li{Let the free will offerings of my mouth please thee O \strong{Lord} : and teach \em{me} thy judgements.}
  \li{Thy testimonies have I claiméd as mine heritage for\strong{ev}er :  and why? They are the very \em{joy} of my heart.}
  \li{I have appliéd my heart to fulfil thy statutes \strong{al}way : even \em{un}to the end.}
  \li{Glory be to the Father and to the \strong{Son} : And to the \em{Ho}ly Spirit. }
  \li{As it was in the beginning is now, and ever \strong{shall} be : World with\em{out} end, Amen. }
}
}
