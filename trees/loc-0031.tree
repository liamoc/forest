\subtree{
  \taxon{Communion}
  \gabc{(c4) RE(d)spón(fh~)sum(g) *() ac(g)cé(gh)pit(ghg) Sí(f)me(ghg)on(hvGFghd.1___) (,) a(d) Spí(g)ri(f)tu(e) San(fg~)cto,(d!ewf.) (;) non(d) vi(d)sú(fg'h)rum(g) se(gf) mor(hj)tem,(ji/jkJ'I) (,) ni(h)si(ji) vi(g)dé(h)ret(ghG'F) Chri(fh)stum(ji) Dó(g)mi(ghg___)ni.(g.) (::)}

\ol{
  \li{
    \ol{
      \li{Nunc dimíttis servum tuum, \strong{Dó}mine: secúndum verbum tu\em{um} in pace.}
      \li{Quia vidérunt óculi mei salutáre \strong{tu}um: quod parásti ante fáciem ómnium \em{po}pulórum.}
      \li{Lumen ad revelatiónem \strong{gén}tium: et glóriam plebis \em{tu}æ Israël. \em{(Repeat Antiphon)}}
    }
  }
  \li{
    \ol{
      \li{Magnus Dóminus, et laudábilis \strong{ni}mis: in civitáte Dei nostri, in monte \em{san}cto ejus.}
      \li{Fundátur exsultatióne univérsæ terræ mons \strong{Si}on: látera Aquilónis, cívitas \em{Re}gis magni. \em{(Repeat Antiphon)}}
    }
  }
  \li{\ol{
    \li{Deus in dómibus ejus cogno\strong{scé}tur: cum sus\em{cí}piet eam.}
    \li{Quóniam ecce reges terræ congre\strong{gá}ti sunt: conve\em{né}runt in unum. \em{(Repeat Antiphon)}}
  }}
  \li{Sicut audívimus, sic vídimus in civitáte Dómini virtútum, in civitáte Dei \strong{nos}tri: Deus fundávit eam \em{in} ætérnum. \em{(Repeat Antiphon)}}
  \li{\ol{
    \li{Suscépimus, Deus, misericórdiam \strong{tu}am: in médio \em{tem}pli tui.}  
    \li{Secúndum nomen tuum, Deus, sic et laus tua in fines \strong{ter}ræ: justítia plena est \em{déx}tera tua. \em{(Repeat Antiphon)}}
  }}
  \li{\ol{
    \li{Lætétur mons Sion, et exsúltent fíliæ \strong{Ju}dæ: propter judícia \em{tu}a, Dómine.}
    \li{Quóniam hic est Deus, Deus noster in æ\strong{tér}num, et in sæculum sæculi: ipse reget \em{nos} in sæcula. \em{(Repeat Antiphon)}}
  }}
  \li{\ol{
    \li{Glória Patri, et \strong{Fí}lio: et Spi\em{rí}tui Sancto.}
    \li{Sicut erat in princípio, et nunc, et \strong{sem}per: et in sæcula sæcu\em{ló}rum. Amen.}
  }}
}
}

  
  
  