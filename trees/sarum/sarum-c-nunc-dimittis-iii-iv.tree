\import{sarum-tones}
\tone-iii-iv{}{Nunc }{ di}{{mí}ttis servum }{ *tu}{um }{ _Dó}{{mi}ne}{{se}cúndum verbum tuum }{ _in }{ pa}{ce.}
\ol{
  \li{Nunc dimíttis servum \strong{tu}um \em{Dó}mine : secúndum verbum tuum \em{in} pace.}
  \li{Quia vidérunt \strong{ó}culi \em{me}i : salutá\em{re} tuum. }
  \li{\strong{Quod} pa\em{rá}sti : ante fáciem omnium po\em{pu}lórum.}
  \li{Lumen ad revelati\strong{ó}nem \em{gén}tium : et glóriam plebis tu\em{e} Israel.}
  \li{Glória \strong{Pa}tri et \em{Fí}lio : et Spirítu\em{i} Sancto.}
  \li{Sicut erat in princípio et \strong{nunc} et \em{sem}per : et in sécula seculó\em{rum}, Amen. }
}